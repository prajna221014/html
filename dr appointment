<!DOCTYPE html>
<html>

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width">
  <title>Docters appointment</title>
</head>

<body>


  <h1>Docters appointment</h1>
  <p>Fill in the form below to book your appointment.</p>
  <hr>

  <form>

    <fieldset>
        <legend>Personal details</legend>

        <label>Your name</label><br>
        <input type="text" id="name" placeholder="enter your full name"><br><br>

        <label>Patient ID</label><br>
         <input type="password" id="pid" placeholder="your secret id"><br><br>

         <label>Date of birth</label>
         <input type="date" id="dob"><br>

    </fieldset>

    <br>

    <fieldset>

          <legend>your visit</legend>

          <select id="doctor">
          <label>choose your dr</label>
          <option value="">--Select a doctor--</option>
          <option value="dr-ray">Dr ray - general</option>
          <option value="dr lee">Dr lee - Teeth</option>
          <option value="dr sam">Dr sam - eyes</option>
          </select><br><br>

          <label>why are you visiting?</label><br>
          <input type="radio" name="reason" value="fever"> fever<br>
          <input type="radio" name="reason" value="cold"> cold<br>
          <input type="radio" name="reason" value="checkup"> checkup<br>
          <input type="radio" name="reason" value="tooth"> tooth pain<br>

          <label>any notes for the dr?</label><br> 
          <textarea id="notes" rows="5" cols="35" placeholder="e.g.
           I have had a sore throaght for 3 days now"></textarea><br>

    </fieldset>

    <br>

    <fieldset>
        <legend>prefered visit day</legend>

        <input type="checkbox" value="mon"> Monday<br>
        <input type="checkbox" value="wed"> wednesday<br>
        <input type="checkbox" value="fri"> friday<br>

    </fieldset>

    <br>
    <input type="submit" value="Book">

  </form>

</body>

</html>